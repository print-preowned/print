# development | production
APP_ENV=development

# Required in production; must match print-web JWT_SECRET
JWT_SECRET=

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=print

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set true for Redis Cloud and other TLS endpoints
REDIS_SSL=false

# Frontend base URL for invite and password-reset links
WEB_APP_URL=http://localhost:3000

# SMTP (optional in development — invite links are logged to stdout)
# Mailtrap sandbox: host sandbox.smtp.mailtrap.io, port 2525 or 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@print.local
SMTP_USE_TLS=true
# Set false only in dev if a corporate proxy breaks TLS verification
SMTP_SSL_VERIFY=true
# Set true to print SMTP conversation in the API server console
SMTP_DEBUG=false
